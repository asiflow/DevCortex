{
  "name": "@devcortex/daemon",
  "version": "0.1.0",
  "description": "DevCortex local daemon — watches a repo, keeps its project graph fresh, and serves the cognition HTTP API + local dashboard on 127.0.0.1.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "devcortex-daemon": "./dist/main.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@devcortex/core": "workspace:*",
    "@devcortex/local-dashboard": "workspace:*",
    "chokidar": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
