# Public base URL of the app (exposed to the browser).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostgreSQL connection string used by lib/db.ts.
DATABASE_URL=postgres://app:app@localhost:5432/sample

# Secret used to sign session cookies (lib/auth.ts). Generate with: openssl rand -hex 32
SESSION_SECRET=replace-me-with-a-32-byte-hex-secret

# NOTE: lib/auth.ts also reads SESSION_MAX_AGE at runtime, but it is intentionally
# left undocumented here so DevCortex's env-documented gate has a real finding.
